# Copy to .env at repo root — single source of truth for API + web.
# Vite loads this via envDir (apps/web/vite.config.ts); API via python-dotenv.

# PostGIS (docker compose up -d db → alembic upgrade head)
# Windows shortcut: .\scripts\docker-up.ps1
DATABASE_URL=postgresql://fifteenmenit:fifteenmenit@localhost:5432/fifteenmenit

# Routing — `auto` probes Valhalla at startup; use `mock` to force simulation
ROUTING_MODE=auto
TRANSIT_MODE=mock
VALHALLA_URL=http://localhost:8002
GTFS_MERGED_PATH=data/gtfs/jakarta-merged.zip

# Web — only VITE_* is exposed to the browser
# Omit VITE_API_URL in dev to use Vite proxy /api → :8000
# VITE_API_URL=http://localhost:8000

# Supabase (optional — geocode_cache read/write)
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
# SUPABASE_SERVICE_ROLE=eyJhbGciOi...   # API writes only; never expose to web

# Real routing: ROUTING_MODE=valhalla + docker compose --profile routing up -d valhalla
# Real transit: TRANSIT_MODE=gtfs + python scripts/download_gtfs.py

# Optional tuning (defaults shown)
# NOMINATIM_URL=https://nominatim.openstreetmap.org
# CACHE_TTL_HOURS=24
# GEOCODE_RATE_LIMIT_PER_SEC=1
